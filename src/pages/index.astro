---
import Layout from '../layouts/Layout.astro';
import { TavernUI } from '../components/TavernUI';
import LZString from 'lz-string';
import { defaultPartyPreset } from '../core/presets/defaultParty';

const defaultOgState = LZString.compressToEncodedURIComponent(JSON.stringify(defaultPartyPreset));

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Agents Party",
  "url": "https://agentsparty.dev",
  "description": "An interactive web-based tool to visually configure and export Agent Orchestration systems.",
  "applicationCategory": "Developer Tool",
  "operatingSystem": "All",
  "author": {
    "@type": "Person",
    "name": "kelset"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout 
  title="Agents Party | Assemble Your Party"
  description="Build and export your Agent Orchestration party. D&D-themed UI for configuring Gemini, Claude, and OpenAI agent teams."
  ogState={defaultOgState}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <main class="relative min-h-screen overflow-hidden text-ink-deep">
    <!-- Decorative Background Element -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl aspect-square bg-gold-600/5 blur-[120px] rounded-full -z-10"
    >
    </div>

    <div class="max-w-6xl mx-auto px-6 py-12 relative">
      <!-- Navigation -->
      <nav
        class="flex justify-between items-center mb-8 bg-parchment-base border-[3px] border-ink-deep p-4 shadow-[4px_4px_0_var(--color-ink-deep)] rounded-sm relative z-50"
      >
        <a href="/" class="flex items-center gap-3 group">
          <img
            src="/images/logo-sm.png"
            alt="Agents Party"
            class="w-10 h-10 group-hover:-translate-y-0.5 group-hover:scale-105 transition-all object-contain rendering-pixelated"
            style="image-rendering: pixelated;"
          />
          <span
            class="font-black tracking-widest text-ink-deep uppercase text-sm group-hover:text-crimson transition-colors font-mono"
            >Agents Party</span
          >
        </a>
        <div
          class="hidden md:flex gap-8 text-sm font-black uppercase tracking-widest text-ink-deep font-mono items-center"
        >
          <a
            href="/compendium"
            class="hover:text-crimson hover:-translate-y-0.5 transition-transform"
            >Compendium</a
          >
          <a
            href="https://github.com/kelset/agent-party-planner"
            class="hover:text-crimson hover:-translate-y-0.5 transition-transform flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
              ><path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path></svg
            >
            GitHub
          </a>
        </div>
        <div
          class="flex md:hidden gap-4 text-[10px] font-black uppercase tracking-widest text-ink-deep font-mono items-center"
        >
          <a href="/compendium" class="hover:text-crimson">Compendium</a>
          <a
            href="https://github.com/kelset/agent-party-planner"
            class="hover:text-crimson"
            title="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
              ><path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path></svg
            >
          </a>
        </div>
      </nav>

      <!-- Mobile Warning Banner -->
      <div
        class="md:hidden mb-8 bg-parchment-base border-[3px] border-ink-deep p-4 shadow-[4px_4px_0_var(--color-ink-deep)] rounded-sm relative z-40 text-center"
      >
        <p
          class="font-black uppercase tracking-widest font-mono text-sm mb-2 text-crimson-600"
        >
          ⚠️ Desktop Recommended
        </p>
        <p class="text-xs">
          Agents Party is a complex orchestration tool. While you can view it on
          mobile, it is best experienced on a larger screen to manage your
          party's dynamic rules and export the workspace. But feel free to learn
          about the meta framework in the <a
            href="/compendium"
            class="underline hover:text-crimson transition-colors">Compendium</a
          >!
        </p>
      </div>

      <!-- Interactive Party Builder -->
      <TavernUI client:load />

      <!-- SEO / Information Section -->
      <section class="mt-24 max-w-4xl mx-auto space-y-16">
        <div class="bg-parchment-base border-[3px] border-ink-deep p-8 shadow-[6px_6px_0_var(--color-ink-deep)] rounded-sm">
          <h2 class="font-black text-2xl uppercase tracking-widest text-ink-deep mb-6 font-mono border-b-[3px] border-ink-deep pb-2 inline-block">How It Works</h2>
          <p class="text-ink-deep font-bold mb-8 text-lg leading-relaxed border-l-4 border-crimson pl-4">
            The Agents Party workflow follows a proven 3-step process: Assemble a specialized roster, 
            Configure their unique personality and responsibilities, and Export a tailored 
            orchestration package for your target AI platform.
          </p>
          <div class="grid md:grid-cols-3 gap-8 text-sm">
            <div class="space-y-3">
              <h3 class="font-black uppercase tracking-wider text-crimson">1. Assemble</h3>
              <p class="text-ink-faded leading-relaxed">Choose your party members from classic RPG classes like Warrior, Wizard, and Ranger. Each has a unique role in your AI orchestration.</p>
            </div>
            <div class="space-y-3">
              <h3 class="font-black uppercase tracking-wider text-crimson">2. Configure</h3>
              <p class="text-ink-faded leading-relaxed">Customize their personalities, responsibilities, and relationships. Define exactly how your agents should interact and collaborate.</p>
            </div>
            <div class="space-y-3">
              <h3 class="font-black uppercase tracking-wider text-crimson">3. Export</h3>
              <p class="text-ink-faded leading-relaxed">Select your target platform (Gemini, Claude, or OpenAI) and export a ready-to-use package with all the necessary prompts and CLI scripts.</p>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-parchment-base border-[3px] border-ink-deep p-8 shadow-[6px_6px_0_var(--color-ink-deep)] rounded-sm">
            <h2 class="font-black text-xl uppercase tracking-widest text-ink-deep mb-4 font-mono">Why Agents Party?</h2>
            <p class="text-sm text-ink-faded leading-relaxed mb-4">
              Building complex multi-agent systems is hard. Agents Party simplifies the process by providing a visual, opinionated framework based on proven agentic engineering patterns.
            </p>
            <ul class="text-sm text-ink-faded space-y-2 list-none">
              <li class="flex items-center gap-2"><span class="text-crimson">✦</span> Platform Agnostic</li>
              <li class="flex items-center gap-2"><span class="text-crimson">✦</span> Local-First / Privacy-Focused</li>
              <li class="flex items-center gap-2"><span class="text-crimson">✦</span> D&D Inspired Workflow</li>
            </ul>
          </div>

          <div class="bg-parchment-base border-[3px] border-ink-deep p-8 shadow-[6px_6px_0_var(--color-ink-deep)] rounded-sm">
            <h2 class="font-black text-xl uppercase tracking-widest text-ink-deep mb-4 font-mono">Technical Core</h2>
            <p class="text-sm text-ink-faded leading-relaxed">
              Under the hood, we use a sophisticated template engine ("The Forge") to generate optimized system prompts. Our orchestration model follows a hierarchical structure: Throne Room (Meta) → GM Session (Coordinator) → Party (Execution).
            </p>
          </div>
        </div>
      </section>
    </div>

    <footer
      class="max-w-6xl mx-auto px-6 py-12 mt-8 border-t-[3px] border-ink-deep/30 flex flex-col md:flex-row justify-between items-center gap-6 text-ink-deep text-xs font-black uppercase tracking-widest font-mono"
    >
      <span>© 2026 Agents Party</span>
      <div class="flex gap-8 text-center md:text-left">
        <span
          >Made with agentic nerdism by <a
            href="https://kelset.dev"
            class="hover:text-crimson hover:-translate-y-0.5 transition-transform"
            >kelset</a
          ></span
        >
        <a
          href="https://github.com/kelset/agent-party-planner"
          class="hover:text-crimson hover:-translate-y-0.5 transition-transform"
          >GitHub</a
        >
      </div>
    </footer>
  </main>
</Layout>
