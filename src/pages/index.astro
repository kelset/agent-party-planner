---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Agent Party Planner | Assemble Your Party">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Decorative Background Element -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl aspect-square bg-gold-600/5 blur-[120px] rounded-full -z-10"
    >
    </div>

    <div class="max-w-6xl mx-auto px-6 py-20 relative">
      <!-- Navigation Placeholder -->
      <nav class="flex justify-between items-center mb-24">
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 bg-crimson rounded rotate-45 flex items-center justify-center border border-gold-600/30"
          >
            <span class="text-white font-bold -rotate-45">A</span>
          </div>
          <span
            class="font-bold tracking-wider text-parchment uppercase text-sm"
            >Agent Party Planner</span
          >
        </div>
        <div class="hidden md:flex gap-8 text-sm font-medium text-slate-400">
          <a href="#war-room" class="hover:text-gold-400 transition-colors"
            >War Room</a
          >
          <a href="#the-party" class="hover:text-gold-400 transition-colors"
            >The Party</a
          >
          <a href="/docs" class="hover:text-gold-400 transition-colors"
            >Compendium</a
          >
        </div>
      </nav>

      <!-- Hero Section -->
      <header class="max-w-3xl mb-20">
        <div
          class="inline-block px-3 py-1 rounded-full border border-gold-600/20 bg-gold-600/5 text-gold-400 text-xs font-bold tracking-widest uppercase mb-6"
        >
          Level 1 Orchestration
        </div>
        <h1
          class="text-6xl md:text-7xl font-extrabold mb-8 leading-tight text-parchment italic"
        >
          Your Quest Begins in the <span class="text-gold-400">War Room.</span>
        </h1>
        <p class="text-xl text-slate-400 leading-relaxed mb-10 max-w-2xl">
          Stop wrestling with raw prompts. Visually assemble a high-performance
          party of specialized agents, define their roles, and export a complete
          orchestration package in seconds.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button class="dnd-button-primary uppercase tracking-widest text-sm">
            Assemble the Party
          </button>
          <button
            class="px-8 py-3 bg-transparent hover:bg-white/5 text-parchment font-bold rounded-lg transition-all border border-tavern-800 uppercase tracking-widest text-sm"
          >
            Read the Rules
          </button>
        </div>
      </header>

      <!-- Feature Grid -->
      <section class="grid md:grid-cols-3 gap-6">
        <div class="dnd-card p-8">
          <div
            class="w-12 h-12 bg-gold-600/10 rounded-lg flex items-center justify-center mb-6 border border-gold-600/20"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 text-gold-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-parchment">The War Room</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            The meta-level brain. Define global rules, environment constraints,
            and high-level goal orchestration.
          </p>
        </div>

        <div class="dnd-card p-8">
          <div
            class="w-12 h-12 bg-crimson/10 rounded-lg flex items-center justify-center mb-6 border border-crimson/20"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 text-crimson"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-parchment">The Party</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Recruit specialized classes like the Ranger (Metrics) or Warrior
            (Execution). Customize their stats and roles.
          </p>
        </div>

        <div class="dnd-card p-8">
          <div
            class="w-12 h-12 bg-blue-600/10 rounded-lg flex items-center justify-center mb-6 border border-blue-600/20"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-parchment">Instant Export</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Download a zipped orchestration folder ready to be dropped into your
            project. One click to deploy.
          </p>
        </div>
      </section>
    </div>

    <footer
      class="max-w-6xl mx-auto px-6 py-12 border-t border-tavern-800 flex flex-col md:flex-row justify-between items-center gap-6 text-slate-500 text-xs uppercase tracking-widest"
    >
      <span>© 2026 Agent Party Planner</span>
      <div class="flex gap-8">
        <span>Powered by Bun & Astro</span>
        <a
          href="https://github.com/kelset/agent-party-planner"
          class="hover:text-gold-400">GitHub</a
        >
      </div>
    </footer>
  </main>
</Layout>
